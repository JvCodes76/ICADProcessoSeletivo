@page "/tasks/edit/{Id:int}"
@attribute [Authorize]
@inject TaskService TaskService
@inject UserService UserService
@inject NavigationManager Navigation

<PageTitle>Editar Tarefa - ICAD</PageTitle>

<div class="container py-4" style="max-width: 700px;">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a href="/tasks" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Voltar
        </a>
        <h2 class="fw-bold mb-0">
            <i class="bi bi-pencil text-primary me-2"></i>Editar Tarefa
        </h2>
    </div>

    @if (_notFound)
    {
        <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i>Tarefa não encontrada.</div>
    }
    else if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        @if (_errorMessage is not null)
        {
            <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@_errorMessage</div>
        }

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Título <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="_model.Titulo" placeholder="Título da tarefa" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Descrição</label>
                        <InputTextArea class="form-control" @bind-Value="_model.Descricao" rows="4" />
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Data de Entrega <span class="text-danger">*</span></label>
                            <InputDate class="form-control" @bind-Value="_model.DataEntrega" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Dificuldade <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="_model.Dificuldade">
                                <option value="">Selecione...</option>
                                <option value="Fácil">Fácil</option>
                                <option value="Médio">Médio</option>
                                <option value="Difícil">Difícil</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Responsável <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="_model.ResponsavelId">
                            <option value="0">Selecione um responsável...</option>
                            @foreach (var user in _users)
                            {
                                <option value="@user.Id">@user.Name (@user.Username)</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Status</label>
                        <InputSelect class="form-select" @bind-Value="_model.Status">
                            <option value="Backlog">Product Backlog</option>
                            <option value="SprintBacklog">Sprint Backlog</option>
                            <option value="Doing">Doing</option>
                            <option value="Revision">Revision</option>
                            <option value="Done">Done</option>
                        </InputSelect>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            <i class="bi bi-check-circle me-1"></i>Salvar Alterações
                        </button>
                        <a href="/tasks" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </EditForm>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private UpdateTaskDto _model = new();
    private List<UserDto> _users = [];
    private string? _errorMessage;
    private bool _loading = true;
    private bool _saving;
    private bool _notFound;

    protected override async Task OnInitializedAsync()
    {
        var taskTask = TaskService.GetByIdAsync(Id);
        var usersTask = UserService.GetAllAsync();
        await Task.WhenAll(taskTask, usersTask);
        var task = taskTask.Result;
        var users = usersTask.Result;
        _users = users;

        if (task is null) { _notFound = true; _loading = false; return; }

        _model = new UpdateTaskDto
        {
            Titulo = task.Titulo,
            Descricao = task.Descricao,
            DataEntrega = task.DataEntrega,
            ResponsavelId = task.ResponsavelId,
            Dificuldade = task.Dificuldade,
            Status = task.Status
        };

        _loading = false;
    }

    private async Task HandleSubmit()
    {
        if (_model.ResponsavelId == 0) { _errorMessage = "Selecione um responsável."; return; }

        _saving = true;
        _errorMessage = null;

        var success = await TaskService.UpdateAsync(Id, _model);
        if (success)
            Navigation.NavigateTo("/tasks");
        else
            _errorMessage = "Erro ao salvar as alterações.";

        _saving = false;
    }
}
