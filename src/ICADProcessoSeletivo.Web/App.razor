<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <Authorizing>
                    <div class="d-flex justify-content-center align-items-center" style="height:100vh">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                </Authorizing>
                <NotAuthorized Context="authState">
                    @if (authState.User.Identity?.IsAuthenticated == true)
                    {
                        <LayoutView Layout="@typeof(MainLayout)">
                            <div class="container py-5 text-center">
                                <i class="bi bi-shield-x text-danger" style="font-size: 4rem;"></i>
                                <h4 class="mt-3 fw-bold">Acesso negado</h4>
                                <p class="text-muted">Você não tem permissão para acessar esta página.</p>
                                <a href="/tasks" class="btn btn-primary mt-2">
                                    <i class="bi bi-arrow-left me-1"></i>Voltar ao início
                                </a>
                            </div>
                        </LayoutView>
                    }
                    else
                    {
                        <ICADProcessoSeletivo.Web.Pages.RedirectToLogin />
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Não encontrado</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">Página não encontrada.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
