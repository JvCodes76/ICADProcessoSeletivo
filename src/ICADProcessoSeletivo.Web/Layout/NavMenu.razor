@inject AuthService AuthService
@inject NavigationManager Navigation

<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/tasks">
            <i class="bi bi-check2-square me-2"></i>ICAD Tarefas
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                <li class="nav-item">
                    <NavLink class="nav-link" href="/tasks" Match="NavLinkMatch.All">
                        <i class="bi bi-list-task me-1"></i>Lista de Tarefas
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="/tasks/add">
                        <i class="bi bi-plus-circle me-1"></i>Adicionar Nova Tarefa
                    </NavLink>
                </li>
                <AuthorizeView Roles="admin">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/users">
                            <i class="bi bi-people me-1"></i>Equipe
                        </NavLink>
                    </li>
                </AuthorizeView>
                <li class="nav-item">
                    <button class="btn btn-danger btn-sm ms-lg-2" @onclick="Logout">
                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                    </button>
                </li>
            </ul>
        </div>
    </div>
</nav>

@code {
    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
